{
  "name": "claude-api-limits",
  "publisher": "fusionxyz",
  "displayName": "Claude API Limits",
  "description": "Cortex API limit takibi by fusion",
  "version": "1.1.0",
  "engines": { "vscode": "^1.74.0" },
  "repository": {"type": "git", "url": "https://github.com/Ubkch/Cortexai-Limit_VS"},
  "license": "MIT",
  "icon": "icon.png",
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeApiLimits.refresh",
        "title": "Claude API Limits: Yenile"
      },
      {
        "command": "claudeApiLimits.setApiKey",
        "title": "Claude API Limits: API Key Ayarla"
      },
      {
        "command": "claudeApiLimits.selectProvider",
        "title": "Claude API Limits: Provider Seç"
      }
    ],
    "configuration": {
      "title": "Claude API Limits",
      "properties": {
        "claudeApiLimits.provider": {
          "type": "string",
          "default": "claude.gg",
          "enum": ["claude.gg", "vertex.claude.gg"],
          "enumDescriptions": [
            "claude.gg — https://claude.gg/api/me?key=sk-...",
            "vertex.claude.gg — https://vertex.claude.gg/api/me?key=sk-..."
          ],
          "description": "API sağlayıcısı"
        },
        "claudeApiLimits.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API anahtarı — URL'deki `sk-...` değeri veya tam URL yapıştırılabilir"
        }
      }
    }
  }
}